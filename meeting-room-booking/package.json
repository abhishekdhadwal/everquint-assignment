{
  "name": "meeting-room-booking",
  "version": "1.0.0",
  "description": "Meeting room booking service API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:reset:test": "node scripts/reset-test-db.js",
    "test": "npm run db:reset:test && npm run db:migrate && node --experimental-vm-modules ./node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.3.1",
    "pg": "^8.20.0",
    "sequelize": "^6.37.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.5",
    "supertest": "^6.3.3"
  },
  "jest": {},
  "keywords": [
    "meeting",
    "booking",
    "api",
    "rooms"
  ],
  "author": "Developer",
  "license": "MIT"
}
